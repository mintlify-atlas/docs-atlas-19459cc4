  "keyFeatures": [
    "Bug tracking with external bug tracker integration (Bugzilla, GitHub, GitLab, etc.)",
    "Git and Bazaar code hosting with merge proposals",
    "Personal Package Archives (PPA) for Ubuntu package publishing",
    "Rosetta translation platform for software internationalization",
    "Blueprint/specification tracking for project planning",
    "Build farm for Snap, Charm, OCI, and Debian packages",
    "REST web service API via lazr.restful",
    "OpenID-based single sign-on authentication",
    "Team and person management with role-based access control",
    "Librarian file storage service"
  ],
  "publicApiSurface": [
    "GET /api/devel/bugs/{id} — Retrieve a bug by ID",
    "GET /api/devel/people/{name} — Retrieve a person or team",
    "GET /api/devel/distributions/{name} — Retrieve a distribution",
    "GET /api/devel/~{person}/+archive/{name} — Retrieve a PPA archive",
    "POST /api/devel/bugs — Create a new bug",
    "PATCH /api/devel/bugs/{id} — Update a bug",
    "GET /api/devel/{project}/+git — List Git repositories for a project",
    "GET /api/devel/{project}/+branches — List branches for a project",
    "GET /api/devel/snaps/{id} — Retrieve a Snap package",
    "GET /api/devel/charms/{id} — Retrieve a Charm package",
    "ILaunchpad XMLRPC interface — Internal XML-RPC API for services"
  ]
}
