{
  "$schema": "https://mintlify.com/docs.json",
  "name": "Launchpad",
  "theme": "maple",
  "colors": {
    "primary": "#caaf3b",
    "light": "#ae345c",
    "dark": "#ea5d2c"
  },
  "favicon": "/favicon.svg",
  "logo": {
    "light": "https://media.brand.dev/ca9099c7-1a65-4df3-bea5-15dd5cd22175.jpg",
    "dark": "https://media.brand.dev/3bff96a3-2515-4c75-b235-83a440c2ddc2.png"
  },
  "navbar": {
    "primary": {
      "type": "github",
      "href": "https://github.com/goulinkh/launchpad"
    }
  },
  "footer": {
    "socials": {
      "github": "https://github.com/goulinkh/launchpad"
    }
  },
  "navigation": {
    "tabs": [
      {
        "tab": "Documentation",
        "groups": [
          {
            "group": "Get Started",
            "pages": [
              "introduction",
              "quickstart",
              "architecture"
            ]
          },
          {
            "group": "Core Features",
            "pages": [
              "features/bugs",
              "features/code-hosting",
              "features/packages",
              "features/translations",
              "features/blueprints",
              "features/builds"
            ]
          },
          {
            "group": "Configuration & Deployment",
            "pages": [
              "deployment/setup",
              "deployment/configuration",
              "deployment/database",
              "deployment/services"
            ]
          },
          {
            "group": "Contributing",
            "pages": [
              "contributing/development",
              "contributing/testing",
              "contributing/security"
            ]
          }
        ]
      },
      {
        "tab": "API Reference",
        "groups": [
          {
            "group": "Web Service API",
            "pages": [
              "api/overview",
              "api/authentication",
              "api/bugs",
              "api/code",
              "api/packages",
              "api/people"
            ]
          }
        ]
      }
    ]
  }
}
